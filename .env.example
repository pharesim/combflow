# Database
POSTGRES_USER=combflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=combflow
DATABASE_URL=postgresql+asyncpg://combflow:change_me@db/combflow

# SQLAlchemy query logging — set true only for local debugging
SQL_ECHO=false

# Caddy reverse proxy sites
# Dev defaults include :80 for plain HTTP
# Production: remove :80 to enable auto TLS via Let's Encrypt
#   CADDY_UI=honeycomb.example.com
#   CADDY_API=api.example.com
CADDY_UI=honeycomb.lvh.me:80
CADDY_API=combflow.lvh.me:80
