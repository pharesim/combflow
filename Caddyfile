{
	auto_https off
	http_port 8080
}

{$CADDY_UI:honeycomb.lvh.me} {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 3
		}
	}
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(), microphone=()"
		Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' https://unpkg.com 'unsafe-inline'; img-src 'self' data: https://images.hive.blog https://img.youtube.com https://images.3speak.tv https://files.peakd.com https://images.ecency.com https://usermedia.actifit.io https://cdn.steemitimages.com https://img.leopedia.io; connect-src 'self' https://api.hive.blog https://techcoderx.com https://api.openhive.network https://images.hive.blog https://nominatim.openstreetmap.org; frame-src https://youtube.com https://www.youtube.com https://youtube-nocookie.com https://www.youtube-nocookie.com https://player.vimeo.com https://play.3speak.tv https://www.instagram.com https://www.skatehype.com https://odysee.com https://rumble.com https://open.spotify.com https://w.soundcloud.com https://emb.d.tube https://lbry.tv https://hivedapps.com about:blank; font-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
	}
	handle /.well-known/security.txt {
		header Content-Type "text/plain; charset=utf-8"
		respond "Contact: https://github.com/pharesim/combflow/issues
Expires: 2027-03-24T00:00:00.000Z
Preferred-Languages: en
" 200
	}
	redir /docs / permanent
	@bot {
		header_regexp User-Agent (?i)(googlebot|bingbot|yandexbot|baiduspider|duckduckbot|slurp|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|applebot|gptbot|claudebot|chatgpt-user|perplexitybot|bytespider|semrushbot|ahrefsbot|dotbot|petalbot|mj12bot)
		not path /static/*
	}
	handle @bot {
		rewrite * /{scheme}://{host}{path}
		reverse_proxy prerender:3000
	}
	handle /static/* {
		header Cache-Control "public, max-age=86400, immutable"
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
	handle {
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
}

{$CADDY_UI_OLD:old.invalid} {
	redir http://{$CADDY_UI}{uri} permanent
}

{$CADDY_API:combflow.lvh.me} {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 3
		}
	}
	handle /.well-known/security.txt {
		header Content-Type "text/plain; charset=utf-8"
		respond "Contact: https://github.com/pharesim/combflow/issues
Expires: 2027-03-24T00:00:00.000Z
Preferred-Languages: en
" 200
	}
	handle /stats {
		header Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
		root * /var/www/goaccess
		rewrite * /report.html
		file_server
	}
	redir / /docs permanent
	@api_paths {
		path /api/* /docs /docs/* /openapi.json /redoc /health /categories /posts/*
	}
	handle @api_paths {
		header Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
	handle {
		respond "Not Found" 404
	}
}
