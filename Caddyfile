# Dev default: plain HTTP on port 80 (honeycomb.lvh.me:80)
# Production: set CADDY_UI=honeycomb.example.com and CADDY_API=api.example.com
#   (no port = Caddy auto-provisions TLS via Let's Encrypt + redirects HTTP→HTTPS)
# Optional: set CADDY_UI_OLD to redirect a previous UI domain to the current one

{$CADDY_UI:honeycomb.lvh.me:80} {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 3
		}
	}
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(), microphone=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}
	redir /docs / permanent
	handle /static/* {
		header Cache-Control "public, max-age=86400, immutable"
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
	handle {
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
}

{$CADDY_UI_OLD:http://old.invalid} {
	redir https://{$CADDY_UI}{uri} permanent
}

{$CADDY_API:combflow.lvh.me:80} {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 3
		}
	}
	handle /stats {
		root * /var/www/goaccess
		rewrite * /report.html
		file_server
	}
	redir / /docs permanent
	# Only allow API paths — block UI routes and static assets
	@api_paths {
		path /api/* /docs /docs/* /openapi.json /redoc /health /categories /posts/*
	}
	handle @api_paths {
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
	# Everything else returns 404
	handle {
		respond "Not Found" 404
	}
}
