# Dev default: plain HTTP on port 80 (honeycomb.lvh.me:80)
# Production: set CADDY_UI=honeycomb.example.com and CADDY_API=api.example.com
#   (no port = Caddy auto-provisions TLS via Let's Encrypt + redirects HTTP→HTTPS)

{$CADDY_UI:honeycomb.lvh.me:80} {
	handle /static/* {
		header Cache-Control "public, max-age=86400, immutable"
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
	handle {
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
}

{$CADDY_API:combflow.lvh.me:80} {
	encode zstd gzip
	reverse_proxy combflow-app:8000
}
