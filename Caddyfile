{
	auto_https off
	http_port 8080
	servers {
		trusted_proxies static private_ranges 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
	}
}

http://{$CADDY_UI:honeycomb.lvh.me} {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 30
		}
	}
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(), microphone=()"
		# unsafe-eval: required by Alpine.js v3 (uses new Function() for x-data expressions; CSP build would require pre-compiling all expressions)
		# unsafe-inline in script-src: required by Cloudflare Web Analytics (injects inline script)
		# unsafe-inline in style-src: required by Leaflet (inline styles on map tiles)
		Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://static.cloudflareinsights.com; style-src 'self' https://unpkg.com 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org; connect-src 'self' https://api.hive.blog https://api.deathwing.me https://techcoderx.com https://api.openhive.network https://images.hive.blog https://nominatim.openstreetmap.org https://cdn.jsdelivr.net https://unpkg.com https://cloudflareinsights.com; frame-src https://youtube.com https://www.youtube.com https://youtube-nocookie.com https://www.youtube-nocookie.com https://player.vimeo.com https://play.3speak.tv https://www.instagram.com https://www.skatehype.com https://odysee.com https://rumble.com https://open.spotify.com https://w.soundcloud.com https://emb.d.tube https://lbry.tv https://hivedapps.com; font-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
	}
	handle /.well-known/security.txt {
		header Content-Type "text/plain; charset=utf-8"
		respond "Contact: https://github.com/pharesim/combflow/issues
Expires: 2027-03-24T00:00:00.000Z
Preferred-Languages: en
" 200
	}
	redir /docs / permanent
	@bot {
		header_regexp User-Agent (?i)(googlebot|bingbot|yandexbot|baiduspider|duckduckbot|slurp|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|applebot|gptbot|claudebot|claudesearchbot|chatgpt-user|perplexitybot|bytespider)
		not path /static/* /sitemap.xml /robots.txt /llms.txt /.well-known/* /posts/* /api/* /categories /health /docs /docs/* /openapi.json /redoc
	}
	handle @bot {
		log_skip
		rewrite * /https://{host}{path}
		reverse_proxy prerender:3000 {
			# Fail fast to the fallback rather than making a crawler wait out a
			# Chromium stall (failure mode 1: prerender unreachable / silent stall).
			transport http {
				dial_timeout 5s
				response_header_timeout 20s
			}
			# Failure mode 2: prerender *responds* with a 5xx (e.g. a 504 Gateway
			# Timeout body). reverse_proxy treats that as a successful proxy and
			# would pass it straight through to the crawler — handle_errors does
			# NOT fire. Intercept the 5xx here and re-proxy to the app's
			# server-rendered floor (proposal 100, Phase 3).
			@prerender_err status 500 502 503 504
			handle_response @prerender_err {
				# The @bot rewrite above replaced {path} with prerender's
				# /https://{host}{path} form; restore the original request URI so
				# the app sees the real path (orig_uri.path predates the rewrite).
				rewrite * {http.request.orig_uri.path}
				encode zstd gzip
				reverse_proxy combflow-app:8000 {
					lb_try_duration 10s
					lb_try_interval 250ms
				}
			}
			# NOT covered here: prerender answering 200 with a thin/empty body (JS
			# eval failed or timed out internally). That passes straight to the
			# crawler — it stays covered by the e2e healthcheck + autoheal, which
			# restart the stuck container. Folding it into this fallback would need
			# server.js to emit 503 (or an X-Prerender-Status header) on a
			# below-threshold render; tracked as the optional prerender/ follow-up
			# in proposal 100, Phase 3. Revisit if Phase 2 shows residual thin-body
			# soft-404s.
		}
	}
	@prerender_internal {
		header User-Agent *Prerender*
	}
	handle @prerender_internal {
		log_skip
		reverse_proxy combflow-app:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}
	handle /static/* {
		# Asset URLs are content-hash versioned (?v=HASH) by the app, so
		# immutable + long max-age is correct — a content change means a new
		# URL, which busts both the browser and Cloudflare cache instantly.
		header Cache-Control "public, max-age=31536000, immutable"
		encode zstd gzip
		reverse_proxy combflow-app:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}
	# Legal pages (/privacy, /terms, /takedown) load only same-origin assets
	# (theme.js, shared.css, legal.css, favicons) — no inline script, no Alpine,
	# no CDN libs, no fetch. So they get a strict CSP that drops both
	# 'unsafe-inline' and 'unsafe-eval' from script-src (proposal 103, Phase 1).
	# This handle-level header replaces the site-level CSP above (verified: single
	# header, no duplicate); must stay ordered before the catch-all handle below.
	# style-src keeps 'unsafe-inline' (harmless here; consistent with the main UI).
	@legal path /privacy /terms /takedown
	handle @legal {
		header Content-Security-Policy "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
		encode zstd gzip
		reverse_proxy combflow-app:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}
	handle {
		encode zstd gzip
		reverse_proxy combflow-app:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}
	handle_errors {
		# Prerender failure mode 1: the @bot reverse_proxy can't reach prerender
		# or it stalls past the transport timeouts above, so reverse_proxy raises
		# a handler error. (Mode 2 — prerender answering with a 5xx — is caught
		# inside the @bot block by handle_response @prerender_err; it never reaches
		# here.) Caddy disallows handle_errors nested inside handle, so it lives at
		# the site level — but the orig_uri.path rewrite keeps it correct for every
		# handler: on the @bot path it undoes the /https://{host}{path} rewrite, and
		# on any other path orig_uri.path is just the original path, so a transient
		# app-upstream error simply re-proxies to the app. Serve the direct app
		# response, which after proposal 100 Phase 1 is a substantive server-rendered
		# page — indexable HTML instead of a soft-404.
		#
		# Edge case (both down): if combflow-app is ALSO unreachable, this
		# reverse_proxy fails too. Caddy does not re-enter handle_errors for an
		# error raised inside handle_errors (no infinite loop), so the crawler gets
		# Caddy's synthetic 502 after the prerender timeout + this lb_try_duration
		# (~40s worst case — the prerender-5xx path dials the app twice: the inner
		# @prerender_err re-proxy, then this handle_errors re-proxy). Acceptable: a
		# total app+prerender outage is not a
		# soft-404 case, and it surfaces the outage rather than masking it.
		rewrite * {http.request.orig_uri.path}
		encode zstd gzip
		reverse_proxy combflow-app:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}
}

# Internal prerender: Chromium fetches via Docker DNS → caddy:8080
http://caddy {
	reverse_proxy combflow-app:8000
}

http://{$CADDY_UI_OLD:old.invalid} {
	redir https://{$CADDY_UI}{uri} permanent
}

http://{$CADDY_API:combflow.lvh.me} {
	request_body {
		max_size 1MB
	}
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 30
		}
	}
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	handle /.well-known/security.txt {
		header Content-Type "text/plain; charset=utf-8"
		respond "Contact: https://github.com/pharesim/combflow/issues
Expires: 2027-03-24T00:00:00.000Z
Preferred-Languages: en
" 200
	}
	handle /stats {
		header Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
		root * /var/www/goaccess
		rewrite * /report.html
		file_server
	}
	redir / /docs permanent
	handle /api/imageproxy {
		# No compression — images are already compressed
		reverse_proxy combflow-app:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}
	@api_paths {
		path /api/* /docs /docs/* /openapi.json /redoc /health /categories /posts/*
	}
	handle @api_paths {
		header Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
		encode zstd gzip
		reverse_proxy combflow-app:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}
	handle {
		respond "Not Found" 404
	}
}
