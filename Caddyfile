{
	auto_https off
	http_port 8080
	servers {
		trusted_proxies static private_ranges 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
	}
}

http://{$CADDY_UI:honeycomb.lvh.me} {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 30
		}
	}
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(), microphone=()"
		# unsafe-eval: required by Alpine.js v3 (uses new Function() for x-data expressions; CSP build would require pre-compiling all expressions)
		# unsafe-inline in script-src: required by Cloudflare Web Analytics (injects inline script)
		# unsafe-inline in style-src: required by Leaflet (inline styles on map tiles)
		Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://static.cloudflareinsights.com; style-src 'self' https://unpkg.com 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org; connect-src 'self' https://api.hive.blog https://api.deathwing.me https://techcoderx.com https://api.openhive.network https://images.hive.blog https://nominatim.openstreetmap.org https://cdn.jsdelivr.net https://unpkg.com https://cloudflareinsights.com; frame-src https://youtube.com https://www.youtube.com https://youtube-nocookie.com https://www.youtube-nocookie.com https://player.vimeo.com https://play.3speak.tv https://www.instagram.com https://www.skatehype.com https://odysee.com https://rumble.com https://open.spotify.com https://w.soundcloud.com https://emb.d.tube https://lbry.tv https://hivedapps.com; font-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
	}
	handle /.well-known/security.txt {
		header Content-Type "text/plain; charset=utf-8"
		respond "Contact: https://github.com/pharesim/combflow/issues
Expires: 2027-03-24T00:00:00.000Z
Preferred-Languages: en
" 200
	}
	redir /docs / permanent
	@bot {
		header_regexp User-Agent (?i)(googlebot|bingbot|yandexbot|baiduspider|duckduckbot|slurp|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|applebot|gptbot|claudebot|claudesearchbot|chatgpt-user|perplexitybot|bytespider)
		not path /static/* /sitemap.xml /robots.txt /llms.txt /.well-known/*
	}
	handle @bot {
		log_skip
		rewrite * /https://{host}{path}
		reverse_proxy prerender:3000
	}
	@prerender_internal {
		header User-Agent *Prerender*
	}
	handle @prerender_internal {
		log_skip
		reverse_proxy combflow-app:8000
	}
	@static_revalidate path /static/*.js /static/*.css
	handle @static_revalidate {
		# JS/CSS change with deploys — short cache + must-revalidate so
		# Cloudflare + browsers re-check every 5 min. 304 responses keep the
		# revalidation cheap (FastAPI's StaticFiles sets ETag/Last-Modified).
		header Cache-Control "public, max-age=300, must-revalidate"
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
	handle /static/* {
		# Images, fonts, favicons — truly immutable per URL, cache hard.
		header Cache-Control "public, max-age=86400, immutable"
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
	handle {
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
}

# Internal prerender: Chromium fetches via Docker DNS → caddy:8080
http://caddy {
	reverse_proxy combflow-app:8000
}

http://{$CADDY_UI_OLD:old.invalid} {
	redir https://{$CADDY_UI}{uri} permanent
}

http://{$CADDY_API:combflow.lvh.me} {
	request_body {
		max_size 1MB
	}
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 30
		}
	}
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	handle /.well-known/security.txt {
		header Content-Type "text/plain; charset=utf-8"
		respond "Contact: https://github.com/pharesim/combflow/issues
Expires: 2027-03-24T00:00:00.000Z
Preferred-Languages: en
" 200
	}
	handle /stats {
		header Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
		root * /var/www/goaccess
		rewrite * /report.html
		file_server
	}
	redir / /docs permanent
	handle /api/imageproxy {
		# No compression — images are already compressed
		reverse_proxy combflow-app:8000
	}
	@api_paths {
		path /api/* /docs /docs/* /openapi.json /redoc /health /categories /posts/*
	}
	handle @api_paths {
		header Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
		encode zstd gzip
		reverse_proxy combflow-app:8000
	}
	handle {
		respond "Not Found" 404
	}
}
